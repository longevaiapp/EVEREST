enum PurchaseOrderStatus {
  BORRADOR
  PENDIENTE
  ENVIADA
  PARCIAL
  RECIBIDA
  CANCELADA
}

// ============================================================================
// HOSPITALIZACIÓN - Terapia de Fluidos
// ============================================================================

model FluidTherapy {
  id String @id @default(cuid())

  hospitalizationId String
  hospitalization   Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  // === DATOS DEL PACIENTE ===
  pesoKg     Float // Peso del paciente en kg
  especie    String // "PERRO", "GATO"
  esCachorro Boolean @default(false) // <4 meses

  // === 1. MANTENIMIENTO ===
  factorMantenimiento Float // 60 (perro), 50 (gato), 80 (cachorro/gatito)
  mlMantenimiento     Float // peso × factor

  // === 2. DÉFICIT POR DESHIDRATACIÓN ===
  porcentajeDeshidratacion Float @default(0) // 5, 8, 10, 12
  mlDeficit                Float @default(0) // peso × %deshid × 10

  // === 3. PÉRDIDAS POR VÓMITO/DIARREA ===
  vomitoPequeno    Int   @default(0) // nº eventos (2 ml/kg cada uno)
  vomitoAbundante  Int   @default(0) // nº eventos (4 ml/kg cada uno)
  diarreaLeve      Int   @default(0) // nº eventos (3 ml/kg cada uno)
  diarreaAbundante Int   @default(0) // nº eventos (5 ml/kg cada uno)
  mlPerdidas       Float @default(0) // total pérdidas

  // === 4. TOTAL Y VELOCIDAD ===
  mlTotal24h Float // mantenimiento + déficit + pérdidas
  mlPorHora  Float // total ÷ 24

  // === 5. AJUSTES ===
  ajusteGeriatrico    Boolean @default(false) // Reducir 20-30%
  ajusteCardiaco      Boolean @default(false) // Reducir 20-30%
  ajusteRenal         Boolean @default(false) // Reducir 20-30%
  porcentajeReduccion Float   @default(0) // 0, 20, 25, 30
  mlAjustado24h       Float? // Total ajustado si aplica reducción
  mlAjustadoPorHora   Float? // ml/hora ajustado

  // === SOLUCIÓN ===
  tipoSolucion String? // "Hartmann", "NaCl 0.9%", "Dextrosa 5%", etc.

  // === NOTAS ===
  notas String? @db.Text

  // === ESTADO ===
  isActive Boolean @default(true)

  // === QUIEN PRESCRIBIÓ ===
  prescribedById String
  prescribedBy   User   @relation(fields: [prescribedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalizationId])
  @@index([isActive])
}

// ============================================================================
// HOSPITALIZACIÓN - Plan Terapéutico y Administración de Medicamentos
// ============================================================================

model TherapyPlanItem {
  id String @id @default(cuid())

  hospitalizationId String
  hospitalization   Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  // === MEDICAMENTO ===
  medicationId   String?
  medication     Medication? @relation(fields: [medicationId], references: [id])
  medicationName String // Nombre (por si no está en catálogo)

  // === DOSIFICACIÓN ===
  dose      String // "10mg", "5ml", etc.
  route     String // "IV", "IM", "SC", "PO"
  frequency String // "cada 8 horas", "BID", "TID"

  // === CÁLCULO DE DOSIS (trazabilidad) ===
  patientWeightKg   Float? // Peso del paciente usado para cálculo
  dosePerKg         Float? // mg/kg aplicado
  calculatedDoseMg  Float? // Dosis total calculada en mg
  volumeMl          Float? // Volumen calculado en ml
  concentrationUsed String? // Concentración usada

  // === HORARIOS ===
  scheduledTimes Json? // ["08:00", "16:00", "00:00"]

  // === ESTADO ===
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime? // Null = indefinido hasta alta

  // === RELACIÓN CON PRESCRIPCIÓN ===
  prescriptionId String?

  // === QUIEN PRESCRIBIÓ ===
  prescribedById String
  prescribedBy   User   @relation(fields: [prescribedById], references: [id])

  // Relaciones
  administrations MedicationAdministration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalizationId])
  @@index([isActive])
}

model MedicationAdministration {
  id String @id @default(cuid())

  therapyItemId String
  therapyItem   TherapyPlanItem @relation(fields: [therapyItemId], references: [id], onDelete: Cascade)

  hospitalizationId String
  hospitalization   Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  // === HORARIO PROGRAMADO ===
  scheduledTime DateTime // Fecha y hora programada

  // === ADMINISTRACIÓN REAL ===
  administeredAt   DateTime? // Fecha y hora real
  administeredById String?
  administeredBy   User?     @relation(fields: [administeredById], references: [id])

  // === ESTADO ===
  status MedicationAdminStatus @default(PENDIENTE)

  // === SI FUE OMITIDO O RETRASADO ===
  reason String?
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalizationId])
  @@index([scheduledTime])
  @@index([status])
}

enum MedicationAdminStatus {
  PENDIENTE
  ADMINISTRADO
  OMITIDO
  RETRASADO
}

// ============================================================================
// HOSPITALIZACIÓN - Neonatos
// ============================================================================

model Neonate {
  id String @id @default(cuid())

  hospitalizationId String
  hospitalization   Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)

  // === IDENTIFICACIÓN ===
  number             Int // Neonato No. (1, 2, 3...)
  identification     String? // "Collar rojo", "Marca en oreja", etc.
  identificationType String? // "Collar", "Marca", "Color", "Otro"
  sex                String? // "Macho", "Hembra"

  // Relaciones
  records NeonateRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalizationId])
}

model NeonateRecord {
  id String @id @default(cuid())

  neonateId String
  neonate   Neonate @relation(fields: [neonateId], references: [id], onDelete: Cascade)

  // === QUIEN REGISTRÓ ===
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  recordedAt   DateTime @default(now())

  // === MEDICIONES ===
  weight          Decimal? @db.Decimal(6, 2) // Peso en gramos
  temperature     Decimal? @db.Decimal(4, 2) // Temperatura °C
  heartRate       Int? // FC (lpm)
  respiratoryRate Int? // FR (rpm)

  // === ESTADO ===
  suction  NeonateSuction?
  activity NeonateActivity?

  notes String?

  createdAt DateTime @default(now())

  @@index([neonateId])
  @@index([recordedAt])
}

enum NeonateSuction {
  ADECUADA
  DEBIL
}

enum NeonateActivity {
  ACTIVO
  LETARGICO
}

// ============================================================================
// CREMATORIO - Sistema de cremación de mascotas
// ============================================================================

model Urn {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  imageUrl    String?  @db.LongText // Base64 image
  price       Decimal  @db.Decimal(10, 2) // Precio con costo (aliados)
  size        UrnSize
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders CremationOrder[]
}

enum UrnSize {
  CHICA
  MEDIANA
  GRANDE
  EXTRA_GRANDE
}

model PackagingRange {
  id                   String   @id @default(cuid())
  minKg                Decimal  @db.Decimal(6, 2)
  maxKg                Decimal  @db.Decimal(6, 2)
  label                String // "Empaque chico", "Empaque mediano", etc.
  requiresTwoOperators Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CremationOrder {
  id     String               @id @default(cuid())
  folio  String               @unique
  status CremationOrderStatus @default(SOLICITADA)

  // === DATOS DE MASCOTA ===
  petName         String
  species         String
  breed           String?
  sex             String?
  age             String?
  color           String?
  characteristics String? @db.Text
  weightKg        Decimal @db.Decimal(6, 2)

  // === EMPAQUE (auto-asignado por peso) ===
  packagingLabel String // e.g. "Empaque mediano"
  requiresTwoOps Boolean @default(false)

  // === SOLICITANTE ===
  clientName  String
  clientPhone String
  clientEmail String?

  // === ORIGEN ===
  originType CremationOriginType @default(DIRECTO)
  originName String? // Nombre de clínica/aliado

  // === RECOLECCIÓN ===
  pickupAddress  String    @db.Text
  pickupDate     DateTime?
  pickupTimeSlot String? // e.g. "10:00–12:00"
  pickupNotes    String?   @db.Text
  assignedToId   String?
  assignedTo     User?     @relation("CremationCollector", fields: [assignedToId], references: [id])
  pickedUpAt     DateTime?

  // === CREMACIÓN ===
  receivedAt       DateTime? // Llegada a crematorio
  cremationStartAt DateTime?
  cremationEndAt   DateTime?
  operatorId       String?
  operator         User?     @relation("CremationOperator", fields: [operatorId], references: [id])

  // === FOTOS ===
  petPhotoUrl   String? @db.LongText // Foto de la mascota (base64)
  afterPhotoUrl String? @db.LongText // Foto de cenizas/urna (base64)

  // === ENTREGA ===
  deliveryDate     DateTime?
  deliveredAt      DateTime?
  deliveredById    String?
  deliveredBy      User?     @relation("CremationDelivery", fields: [deliveredById], references: [id])
  receiverName     String?
  receiverPhone    String?
  deliveryNotes    String?   @db.Text
  deliveryEvidence String? // URL foto evidencia
  signatureData    String?   @db.LongText // Firma digital de recepción (base64)

  // === URNA ===
  urnId String?
  urn   Urn?    @relation(fields: [urnId], references: [id])

  // === GENERAL ===
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  payments   CremationPayment[]
  statusLogs CremationStatusLog[]

  @@index([folio])
  @@index([status])
  @@index([assignedToId])
  @@index([operatorId])
  @@index([deliveredById])
  @@index([pickupDate])
  @@index([createdAt])
}

enum CremationOrderStatus {
  SOLICITADA
  RECOLECCION_PROGRAMADA
  RECOLECCION_REALIZADA
  EN_CREMATORIO
  EN_PROCESO
  LISTA_PARA_ENTREGA
  ENTREGADA
  CANCELADA
}

enum CremationOriginType {
  CLINICA
  ALIADO
  DIRECTO
}

model CremationPayment {
  id             String                 @id @default(cuid())
  orderId        String
  order          CremationOrder         @relation(fields: [orderId], references: [id])
  amount         Decimal                @db.Decimal(10, 2)
  method         CremationPaymentMethod
  status         CremationPaymentStatus @default(PENDIENTE)
  reference      String? // Referencia de pago
  registeredById String?
  registeredBy   User?                  @relation("CremationPaymentRegistered", fields: [registeredById], references: [id])
  notes          String?                @db.Text
  paidAt         DateTime?
  createdAt      DateTime               @default(now())

  @@index([orderId])
  @@index([status])
}

enum CremationPaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum CremationPaymentStatus {
  PENDIENTE
  PAGADO
  FALLIDO
}

model CremationStatusLog {
  id             String                @id @default(cuid())
  orderId        String
  order          CremationOrder        @relation(fields: [orderId], references: [id])
  previousStatus CremationOrderStatus?
  newStatus      CremationOrderStatus
  changedById    String?
  changedBy      User?                 @relation("CremationStatusChanger", fields: [changedById], references: [id])
  notes          String?               @db.Text
  createdAt      DateTime              @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model CremationSupply {
  id        String   @id @default(cuid())
  name      String
  category  String // BOLSA, CAJA, ETIQUETA, QUIMICO, OTRO
  stock     Int      @default(0)
  minStock  Int      @default(5)
  unit      String   @default("pzas")
  notes     String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ============================================================================
// BANCO DE SANGRE
// ============================================================================

enum DonorStatus {
  ACTIVO
  TEMPORALMENTE_NO_APTO
  RETIRADO
}

enum EvaluationResult {
  APTO
  NO_APTO
}

enum RestraintMethod {
  FISICA
  SEDACION
}

enum BloodProductType {
  SANGRE_TOTAL
  CONCENTRADO_ERITROCITARIO
  PLASMA
}

enum BloodUnitStatus {
  DISPONIBLE
  RESERVADA
  UTILIZADA
  CADUCADA
  DESCARTADA
}

enum BloodAlertType {
  PROXIMA_CADUCIDAD
  CADUCADA
  DONADOR_ELEGIBLE
  UNIDAD_ANTIGUA
  SOLICITUD_TRANSFUSION
}

enum TransfusionRequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  COMPLETADA
  CANCELADA
}

enum TransfusionUrgency {
  NORMAL
  URGENTE
  EMERGENCIA
}

model BloodDonor {
  id    String  @id @default(cuid())
  petId String?
  pet   Pet?    @relation(fields: [petId], references: [id])

  // Datos standalone (usados si petId es null)
  nombre     String?
  especie    String?
  raza       String?
  edad       String?
  sexo       String?
  peso       Float?
  color      String?
  ownerName  String?
  ownerPhone String?
  ownerEmail String?

  estado              DonorStatus @default(ACTIVO)
  tipoSanguineo       String?
  fechaUltimaDonacion DateTime?
  totalDonaciones     Int         @default(0)
  notas               String?     @db.Text

  registeredById String
  registeredBy   User   @relation("BloodDonorRegisteredBy", fields: [registeredById], references: [id])

  evaluations     DonorEvaluation[]
  diagnosticTests DonorDiagnosticTest[]
  donations       BloodDonation[]
  alerts          BloodBankAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([petId])
  @@index([estado])
  @@index([tipoSanguineo])
}

model DonorEvaluation {
  id          String     @id @default(cuid())
  donorId     String
  donor       BloodDonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  fecha       DateTime   @default(now())
  evaluatorId String
  evaluator   User       @relation("DonorEvaluations", fields: [evaluatorId], references: [id])

  temperatura            Float?
  frecuenciaCardiaca     Int?
  frecuenciaRespiratoria Int?
  mucosas                String?
  tiempoLlenadoCapilar   String?
  condicionCorporal      String?
  observaciones          String?          @db.Text
  resultado              EvaluationResult

  createdAt DateTime @default(now())

  @@index([donorId])
}

model DonorDiagnosticTest {
  id      String     @id @default(cuid())
  donorId String
  donor   BloodDonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  fecha   DateTime   @default(now())
  metodo  String?

  // Hematología
  hematocrito Float?
  hemoglobina Float?
  eritrocitos Float?
  leucocitos  Float?
  plaquetas   Float?

  // Pruebas infecciosas - Perros
  ehrlichia   String?
  anaplasma   String?
  babesia     String?
  dirofilaria String?
  brucella    String?

  // Pruebas infecciosas - Gatos
  felv        String?
  fiv         String?
  hemoplasmas String?

  // Tipificación
  tipificacionSanguinea String?

  registeredById String
  registeredBy   User    @relation("DonorDiagnosticTests", fields: [registeredById], references: [id])
  observaciones  String? @db.Text

  createdAt DateTime @default(now())

  @@index([donorId])
}

model BloodDonation {
  id       String     @id @default(cuid())
  donorId  String
  donor    BloodDonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  fecha    DateTime   @default(now())
  medicoId String
  medico   User       @relation("BloodDonationMedico", fields: [medicoId], references: [id])

  volumenMl     Float
  pesoDonadorKg Float
  tipoBolsa     String?

  metodoContencion     RestraintMethod
  // Sedación (si aplica)
  farmacoUtilizado     String?
  dosisMgKg            Float?
  dosisTotal           Float?
  horaAdministracion   DateTime?
  reversionAplicada    Boolean?
  descripcionProtocolo String?         @db.Text

  observaciones String? @db.Text

  unit BloodUnit?

  createdAt DateTime @default(now())

  @@index([donorId])
  @@index([fecha])
}

model BloodUnit {
  id           String        @id @default(cuid())
  codigoUnidad String        @unique
  donationId   String        @unique
  donation     BloodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  tipoProducto     BloodProductType
  volumenMl        Float
  tipoSanguineo    String?
  fechaRecoleccion DateTime
  fechaCaducidad   DateTime
  status           BloodUnitStatus  @default(DISPONIBLE)

  temperaturaAlmacenamiento Float?
  ubicacion                 String?
  notas                     String? @db.Text

  transfusions BloodTransfusion[]
  alerts       BloodBankAlert[]   @relation("BloodUnitAlerts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tipoSanguineo])
  @@index([fechaCaducidad])
}

model BloodTransfusionRequest {
  id                String           @id @default(cuid())
  petId             String?
  pet               Pet?             @relation("BloodTransfusionRequests", fields: [petId], references: [id])
  consultationId    String?
  consultation      Consultation?    @relation(fields: [consultationId], references: [id])
  hospitalizationId String?
  hospitalization   Hospitalization? @relation(fields: [hospitalizationId], references: [id])

  // Info del receptor (si no está registrado)
  recipientName    String?
  recipientSpecies String?

  solicitadoPorId String
  solicitadoPor   User   @relation("BloodTransfusionRequestSolicitor", fields: [solicitadoPorId], references: [id])

  tipoProducto      BloodProductType
  tipoSanguineo     String?
  urgencia          TransfusionUrgency @default(NORMAL)
  volumenEstimadoMl Float?
  motivo            String             @db.Text
  notas             String?            @db.Text

  status         TransfusionRequestStatus @default(PENDIENTE)
  procesadoPorId String?
  procesadoPor   User?                    @relation("BloodTransfusionRequestProcessor", fields: [procesadoPorId], references: [id])
  procesadoAt    DateTime?
  motivoRechazo  String?                  @db.Text

  // Transfusión resultante
  transfusionId String?           @unique
  transfusion   BloodTransfusion? @relation(fields: [transfusionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([petId])
  @@index([status])
  @@index([urgencia])
  @@index([consultationId])
  @@index([hospitalizationId])
}

model BloodTransfusion {
  id     String    @id @default(cuid())
  unitId String
  unit   BloodUnit @relation(fields: [unitId], references: [id])

  // Receptor registrado
  recipientPetId String?
  recipientPet   Pet?    @relation(fields: [recipientPetId], references: [id])

  // Receptor externo (no registrado)
  recipientName       String?
  recipientSpecies    String?
  recipientBreed      String?
  recipientOwnerName  String?
  recipientOwnerPhone String?

  // Vinculación con consulta/hospitalización
  consultationId    String?
  consultation      Consultation?    @relation(fields: [consultationId], references: [id])
  hospitalizationId String?
  hospitalization   Hospitalization? @relation(fields: [hospitalizationId], references: [id])

  // Solicitud que originó esta transfusión
  request BloodTransfusionRequest?

  medicoId              String
  medico                User     @relation("BloodTransfusionMedico", fields: [medicoId], references: [id])
  fechaTransfusion      DateTime @default(now())
  volumenTransfundidoMl Float

  reacciones    String? @db.Text
  observaciones String? @db.Text

  createdAt DateTime @default(now())

  @@index([unitId])
  @@index([recipientPetId])
  @@index([consultationId])
  @@index([hospitalizationId])
}

model BloodBankAlert {
  id      String         @id @default(cuid())
  tipo    BloodAlertType
  unitId  String?
  unit    BloodUnit?     @relation("BloodUnitAlerts", fields: [unitId], references: [id], onDelete: Cascade)
  donorId String?
  donor   BloodDonor?    @relation(fields: [donorId], references: [id], onDelete: Cascade)

  mensaje       String
  prioridad     Priority  @default(MEDIA)
  resuelta      Boolean   @default(false)
  resueltaAt    DateTime?
  resueltaPorId String?
  resueltaPor   User?     @relation("BloodAlertResolver", fields: [resueltaPorId], references: [id])

  createdAt DateTime @default(now())

  @@index([tipo])
  @@index([resuelta])
}

model BloodBankConfig {
  id                       String   @id @default(cuid())
  diasCaducidadSangreTotal Int      @default(35)
  diasCaducidadConcentrado Int      @default(42)
  diasCaducidadPlasma      Int      @default(365)
  diasAlertaCaducidad      Int      @default(7)
  intervaloMinPerros       Int      @default(56) // 8 semanas
  intervaloMinGatos        Int      @default(84) // 12 semanas
  hematocritoMinPerros     Float    @default(40)
  hematocritoMinGatos      Float    @default(30)
  updatedAt                DateTime @updatedAt
}
