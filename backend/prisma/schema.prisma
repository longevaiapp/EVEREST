// prisma/schema.prisma
// VET-OS Database Schema - EVEREST Project
// Version: 1.0
// Date: January 21, 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SISTEMA - Entidades base del sistema
// ============================================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String // Hashed with bcrypt
  nombre       String
  rol          UserRole
  especialidad String? // Solo para médicos
  telefono     String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  notifications             Notification[]
  tasksAssigned             Task[]                     @relation("TaskAssignee")
  tasksCreated              Task[]                     @relation("TaskCreator")
  consultations             Consultation[]
  labRequestsMade           LabRequest[]               @relation("LabRequestedBy")
  labRequestsDone           LabRequest[]               @relation("LabCompletedBy")
  prescriptions             Prescription[]
  surgeriesLead             Surgery[]                  @relation("SurgeonLead")
  hospitalizations          Hospitalization[]
  monitorings               Monitoring[]
  medicalNotes              MedicalNote[]
  dispenses                 Dispense[]
  stockMovements            StockMovement[]
  alertsResolved            StockAlert[]
  purchaseOrdersCreated     PurchaseOrder[]            @relation("POCreator")
  purchaseOrdersReceived    PurchaseOrder[]            @relation("POReceiver")
  therapyPlanItems          TherapyPlanItem[]
  medicationAdmins          MedicationAdministration[]
  neonateRecords            NeonateRecord[]
  preventiveMedicineRecords PreventiveMedicineRecord[]
  vaccinesApplied           VaccineRecord[]            @relation("VaccineAppliedBy")
  dewormingsApplied         DewormingRecord[]          @relation("DewormingAppliedBy")
  fluidTherapies            FluidTherapy[]

  // Crematorio
  cremationCollections   CremationOrder[]     @relation("CremationCollector")
  cremationOperations    CremationOrder[]     @relation("CremationOperator")
  cremationDeliveries    CremationOrder[]     @relation("CremationDelivery")
  cremationPayments      CremationPayment[]   @relation("CremationPaymentRegistered")
  cremationStatusChanges CremationStatusLog[] @relation("CremationStatusChanger")

  // Banco de Sangre
  bloodDonorsRegistered             BloodDonor[]              @relation("BloodDonorRegisteredBy")
  donorEvaluations                  DonorEvaluation[]         @relation("DonorEvaluations")
  donorDiagnosticTests              DonorDiagnosticTest[]     @relation("DonorDiagnosticTests")
  bloodDonationsMedico              BloodDonation[]           @relation("BloodDonationMedico")
  bloodTransfusionsMedico           BloodTransfusion[]        @relation("BloodTransfusionMedico")
  bloodAlertsResolved               BloodBankAlert[]          @relation("BloodAlertResolver")
  bloodTransfusionRequestsSolicitor BloodTransfusionRequest[] @relation("BloodTransfusionRequestSolicitor")
  bloodTransfusionRequestsProcessor BloodTransfusionRequest[] @relation("BloodTransfusionRequestProcessor")

  @@index([email])
  @@index([rol])
}

enum UserRole {
  ADMIN
  RECEPCION
  MEDICO
  LABORATORIO
  FARMACIA
  ESTILISTA
  HOSPITALIZACION
  RECOLECTOR
  OPERADOR_CREMATORIO
  ENTREGA
  BANCO_SANGRE
}

// ============================================================================
// CONFIGURACIÓN DE LA CLÍNICA
// ============================================================================

model BusinessInfo {
  id String @id @default(cuid())

  // === DATOS DE LA CLÍNICA ===
  clinicName    String
  clinicAddress String  @db.Text
  clinicCity    String?
  clinicState   String?
  clinicZip     String?
  clinicPhone   String
  clinicEmail   String?
  clinicWebsite String?
  clinicLogo    String? @db.Text // Base64 o URL

  // === DATOS FISCALES ===
  taxId   String? // RFC en México, EIN en USA, etc.
  taxName String? // Razón social

  // === VETERINARIO RESPONSABLE ===
  vetName      String // Nombre del veterinario responsable
  vetLicense   String // Cédula profesional / Licencia
  vetSpecialty String? // Especialidad
  vetSignature String? @db.LongText // Firma digital (base64)

  // === CONFIGURACIÓN DE RECETAS ===
  prescriptionHeader   String? @db.Text // Texto adicional en header
  prescriptionFooter   String? @db.Text // Instrucciones generales
  prescriptionWarnings String? @db.Text // Advertencias estándar

  // === TARIFAS DE HOSPITALIZACIÓN ===
  tarifaHospGeneral     Decimal? @db.Decimal(10, 2)
  tarifaHospUCI         Decimal? @db.Decimal(10, 2)
  tarifaHospNeonatos    Decimal? @db.Decimal(10, 2)
  tarifaHospInfecciosos Decimal? @db.Decimal(10, 2)

  // === TARIFAS DE CONSULTA ===
  tarifaConsultaGeneral       Decimal? @db.Decimal(10, 2)
  tarifaConsultaEspecializada Decimal? @db.Decimal(10, 2)
  tarifaUrgencias             Decimal? @db.Decimal(10, 2)

  // === TARIFAS DE ESTUDIOS ===
  tarifaBH           Decimal? @db.Decimal(10, 2) // Biometría Hemática
  tarifaQS           Decimal? @db.Decimal(10, 2) // Química Sanguínea
  tarifaRX           Decimal? @db.Decimal(10, 2) // Rayos X
  tarifaUS           Decimal? @db.Decimal(10, 2) // Ultrasonido
  tarifaEGO          Decimal? @db.Decimal(10, 2) // Examen General de Orina
  tarifaECG          Decimal? @db.Decimal(10, 2) // Electrocardiograma
  tarifaElectrolitos Decimal? @db.Decimal(10, 2)
  tarifaSNAP         Decimal? @db.Decimal(10, 2)

  // === AUDITORÍA ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  tipo      NotificationType
  titulo    String
  mensaje   String           @db.Text
  leida     Boolean          @default(false)
  data      Json? // Datos adicionales (patientId, etc.)
  createdAt DateTime         @default(now())

  @@index([userId, leida])
  @@index([createdAt])
}

enum NotificationType {
  NUEVO_PACIENTE
  TRIAGE_COMPLETADO
  ESTUDIOS_SOLICITADOS
  RESULTADOS_LISTOS
  RECETA_PENDIENTE
  MEDICAMENTOS_LISTOS
  CIRUGIA_PROGRAMADA
  ALTA_PENDIENTE
  STOCK_BAJO
  CITA_AGENDADA_MEDICO
  CREMACION_STATUS
  BANCO_SANGRE
  GENERAL
}

model Task {
  id          String     @id @default(cuid())
  titulo      String
  descripcion String?    @db.Text
  tipo        TaskType
  prioridad   Priority
  estado      TaskStatus @default(PENDIENTE)

  // Asignación
  assigneeId  String?
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User    @relation("TaskCreator", fields: [createdById], references: [id])

  // Referencias opcionales
  petId   String?
  pet     Pet?    @relation(fields: [petId], references: [id])
  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id])

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([assigneeId, estado])
  @@index([tipo, prioridad])
}

enum TaskType {
  TRIAGE
  CONSULTA
  LABORATORIO
  FARMACIA
  CIRUGIA
  ALTA
  GENERAL
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum Priority {
  ALTA
  MEDIA
  BAJA
}

// ============================================================================
// RECEPCIÓN - Propietarios, Mascotas, Visitas, Citas, Pagos
// ============================================================================

model Owner {
  id           String   @id @default(cuid())
  nombre       String
  telefono     String   @unique
  email        String?
  direccion    String?  @db.Text
  ciudad       String?
  codigoPostal String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  pets Pet[]

  @@index([telefono])
  @@index([nombre])
}

model Pet {
  id          String @id @default(cuid())
  numeroFicha String @unique // VET-001, VET-002...
  ownerId     String
  owner       Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // === DATOS BÁSICOS ===
  nombre            String
  especie           Species
  raza              String?
  sexo              Sexo
  fechaNacimiento   DateTime?
  peso              Float?
  color             String?
  condicionCorporal BodyCondition?
  fotoUrl           String?        @db.LongText // Base64 encoded image

  // === HISTORIAL MÉDICO ===
  snapTest         String? @db.Text
  analisisClinicos String? @db.Text
  antecedentes     String? @db.Text

  // === VACUNAS Y DESPARASITACIÓN ===
  desparasitacionExterna Boolean?
  ultimaDesparasitacion  DateTime?
  vacunasTexto           String?   @db.Text
  vacunasActualizadas    Boolean?
  ultimaVacuna           DateTime?

  // === CIRUGÍAS ===
  esterilizado    Boolean?
  otrasCirugias   Boolean?
  detalleCirugias String?  @db.Text

  // === INFO REPRODUCTIVA (Hembras) ===
  ultimoCelo     DateTime?
  cantidadPartos Int?
  ultimoParto    DateTime?

  // === ALIMENTACIÓN ===
  alimento                 String?
  porcionesPorDia          String?
  otrosAlimentos           String?
  frecuenciaOtrosAlimentos String?

  // === ALERGIAS Y PATOLOGÍAS ===
  alergias             String? @db.Text
  enfermedadesCronicas String? @db.Text

  // === ESTILO DE VIDA ===
  conviveOtrasMascotas Boolean?
  cualesMascotas       String?
  actividadFisica      Boolean?
  frecuenciaActividad  String?
  saleViaPublica       Boolean?
  frecuenciaSalida     String?
  otrosDatos           String?  @db.Text

  // === METADATA ===
  estado        PatientStatus @default(RECIEN_LLEGADO)
  fechaIngreso  DateTime      @default(now())
  primeraVisita Boolean       @default(true)
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  visits                    Visit[]
  appointments              Appointment[]
  consultations             Consultation[]
  labRequests               LabRequest[]
  prescriptions             Prescription[]
  surgeries                 Surgery[]
  hospitalizations          Hospitalization[]
  medicalNotes              MedicalNote[]
  dispenses                 Dispense[]
  vaccineRecords            VaccineRecord[]
  dewormingRecords          DewormingRecord[]
  preventiveMedicineRecords PreventiveMedicineRecord[]
  tasks                     Task[]

  // Banco de Sangre
  bloodDonorProfiles       BloodDonor[]
  bloodTransfusions        BloodTransfusion[]
  bloodTransfusionRequests BloodTransfusionRequest[] @relation("BloodTransfusionRequests")

  @@index([ownerId])
  @@index([numeroFicha])
  @@index([nombre])
  @@index([estado])
}

model VaccineRecord {
  id    String @id @default(cuid())
  petId String
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  // === VACUNA ===
  nombre          String // Tipo: Quíntuple, Antirrábica, etc.
  marca           String? // Marca del fabricante
  nombreComercial String? // Nombre comercial

  // === TRAZABILIDAD ===
  medicationId   String? // FK → Medication (si viene de inventario)
  medication     Medication? @relation(fields: [medicationId], references: [id])
  lote           String?
  fechaCaducidad DateTime? // Fecha de vencimiento del lote

  // === FECHAS ===
  fecha        DateTime // Fecha de aplicación
  proximaDosis DateTime? // Próximo refuerzo

  // === APLICACIÓN ===
  aplicadaPor       String? // Nombre del veterinario
  aplicadoPorId     String? // FK → User
  aplicadoPorUser   User?   @relation("VaccineAppliedBy", fields: [aplicadoPorId], references: [id])
  viaAdministracion String? // SC, IM, Intranasal, etc.

  // === COSTO ===
  costo Decimal? @db.Decimal(10, 2)

  // === RELACIÓN CON VISITA ===
  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id])

  notas     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([petId, proximaDosis])
  @@index([medicationId])
  @@index([visitId])
}

model DewormingRecord {
  id    String @id @default(cuid())
  petId String
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  // === PRODUCTO ===
  marca           String
  nombreComercial String
  tipo            String // 'Interna', 'Externa', 'Ambas'

  // === TRAZABILIDAD ===
  medicationId String? // FK → Medication (si viene de inventario)
  medication   Medication? @relation(fields: [medicationId], references: [id])
  lote         String?

  // === FECHAS ===
  fecha             DateTime @default(now())
  proximaAplicacion DateTime

  // === APLICACIÓN ===
  aplicadoPor     String?
  aplicadoPorId   String?
  aplicadoPorUser User?   @relation("DewormingAppliedBy", fields: [aplicadoPorId], references: [id])

  // === COSTO ===
  costo Decimal? @db.Decimal(10, 2)

  // === RELACIÓN CON VISITA ===
  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id])

  notas     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([petId, proximaAplicacion])
  @@index([medicationId])
  @@index([visitId])
}

model PreventiveMedicineRecord {
  id      String @id @default(cuid())
  visitId String @unique
  visit   Visit  @relation(fields: [visitId], references: [id])
  petId   String
  pet     Pet    @relation(fields: [petId], references: [id])

  // === EXAMEN FÍSICO BÁSICO ===
  temperatura            Decimal? @db.Decimal(4, 2)
  peso                   Decimal? @db.Decimal(6, 2)
  frecuenciaCardiaca     Int?
  frecuenciaRespiratoria Int?
  condicionGeneral       String? // 'Normal', 'Requiere atención'

  // === SERVICIOS APLICADOS ===
  vacunasAplicadas         Int @default(0)
  desparasitantesAplicados Int @default(0)

  // === OBSERVACIONES ===
  observaciones String? @db.Text

  // === APLICADO POR ===
  aplicadoPorId String
  aplicadoPor   User   @relation(fields: [aplicadoPorId], references: [id])

  // === COSTO TOTAL ===
  totalCost Decimal @default(0) @db.Decimal(10, 2)

  // === ESTADO ===
  status String @default("COMPLETADO") // COMPLETADO, PENDIENTE_PAGO

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([petId])
  @@index([aplicadoPorId])
}

enum Species {
  PERRO
  GATO
  AVE
  ROEDOR
  REPTIL
  OTRO
}

enum Sexo {
  MACHO
  HEMBRA
}

enum BodyCondition {
  MUY_DELGADO
  DELGADO
  IDEAL
  SOBREPESO
  OBESO
}

enum PatientStatus {
  RECIEN_LLEGADO
  EN_ESPERA
  EN_CONSULTA
  EN_ESTUDIOS
  EN_FARMACIA
  CIRUGIA_PROGRAMADA
  EN_CIRUGIA
  HOSPITALIZADO
  LISTO_PARA_ALTA
  ALTA
  EN_ESTETICA
  ESTETICA_COMPLETADA
}

model Visit {
  id          String      @id @default(cuid())
  petId       String
  pet         Pet         @relation(fields: [petId], references: [id])
  arrivalTime DateTime    @default(now())
  status      VisitStatus @default(RECIEN_LLEGADO)

  // === SERVICE TYPE (Medical vs Grooming) ===
  serviceType ServiceType @default(MEDICO)

  // === TRIAGE (for Medical visits) ===
  tipoVisita    VisitType?
  motivo        String?    @db.Text
  prioridad     Priority?
  peso          Float?
  temperatura   Float?
  primeraVisita Boolean    @default(false)
  antecedentes  String?    @db.Text

  // === SÍNTOMAS (capturados en registro/triage) ===
  sintomas              String? @db.Text // JSON array de síntomas seleccionados
  duracionSintomas      String?
  comportamiento        String?
  apetito               String?
  agua                  String?
  orina                 String?
  heces                 String?
  otrosDetallesSintomas String? @db.Text

  // === ASIGNACIÓN ===
  assignedDoctorId  String?
  assignedStylistId String?

  // === ALTA ===
  dischargeNotes String?   @db.Text
  dischargedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  consultation             Consultation?
  payment                  Payment?
  tasks                    Task[]
  groomingService          GroomingService?
  preventiveMedicineRecord PreventiveMedicineRecord?
  vaccineRecords           VaccineRecord[]
  dewormingRecords         DewormingRecord[]

  @@index([petId])
  @@index([status])
  @@index([arrivalTime])
  @@index([serviceType])
}

enum VisitStatus {
  RECIEN_LLEGADO
  EN_ESPERA
  EN_CONSULTA
  EN_ESTUDIOS
  EN_FARMACIA
  CIRUGIA_PROGRAMADA
  EN_CIRUGIA
  HOSPITALIZADO
  LISTO_PARA_ALTA
  ALTA
  EN_ESTETICA
  ESTETICA_COMPLETADA
  EN_MEDICINA_PREVENTIVA
  MEDICINA_PREVENTIVA_COMPLETADA
}

enum ServiceType {
  MEDICO
  ESTETICA
  MEDICINA_PREVENTIVA
}

enum VisitType {
  CONSULTA_GENERAL
  SEGUIMIENTO
  MEDICINA_PREVENTIVA
  EMERGENCIA
}

model Appointment {
  id          String          @id @default(cuid())
  petId       String
  pet         Pet             @relation(fields: [petId], references: [id])
  fecha       DateTime        @db.Date
  hora        String
  tipo        AppointmentType
  motivo      String          @db.Text
  confirmada  Boolean         @default(false)
  cancelada   Boolean         @default(false)
  notas       String?         @db.Text
  createdById String?

  // === STATUS FLOW ===
  status  AppointmentStatus @default(PENDIENTE)
  visitId String? // Link to Visit when patient checks in

  // === CITAS AGENDADAS POR MÉDICO ===
  creadaPor     String? // "MEDICO" o "RECEPCION"
  agendadaPorId String? // ID del médico que agendó (si aplica)
  labRequestId  String? // ID del resultado de lab relacionado (si aplica)
  metadata      Json? // Datos adicionales (teléfono owner, etc)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([petId])
  @@index([status])
  @@index([creadaPor])
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  EN_CONSULTA
  COMPLETADA
  NO_ASISTIO
  CANCELADA
}

enum AppointmentType {
  CONSULTA_GENERAL
  SEGUIMIENTO
  VACUNACION
  CIRUGIA
  EMERGENCIA
  ESTETICA
  MEDICINA_PREVENTIVA
}

model Payment {
  id          String        @id @default(cuid())
  visitId     String        @unique
  visit       Visit         @relation(fields: [visitId], references: [id])
  total       Decimal       @db.Decimal(10, 2)
  metodoPago  PaymentMethod
  fecha       DateTime      @default(now())
  recibidoPor String?
  notas       String?       @db.Text
  createdAt   DateTime      @default(now())

  @@index([fecha])
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

// ============================================================================
// ESTÉTICA / GROOMING - Servicios de estética para mascotas
// ============================================================================

model GroomingService {
  id      String @id @default(cuid())
  visitId String @unique
  visit   Visit  @relation(fields: [visitId], references: [id])
  petId   String

  // === DATE & TIME ===
  serviceDate DateTime @default(now())
  checkInTime DateTime @default(now())

  // === SECTION 3: PET'S GENERAL CONDITION ===
  conditionCalm          Boolean @default(false)
  conditionNervous       Boolean @default(false)
  conditionAggressive    Boolean @default(false)
  conditionAnxious       Boolean @default(false)
  conditionBites         Boolean @default(false)
  conditionNeedsMuzzle   Boolean @default(false)
  conditionFirstGrooming Boolean @default(false)
  conditionObservations  String? @db.Text

  // === SECTION 4: BATH SERVICES ===
  bathBasic         Boolean @default(false)
  bathMedicated     Boolean @default(false)
  bathFleaTreatment Boolean @default(false)
  bathMoisturizing  Boolean @default(false)
  bathDrying        Boolean @default(false)

  // === SECTION 4: HAIRCUT & GROOMING ===
  haircutFull       Boolean @default(false)
  haircutDeshedding Boolean @default(false)
  haircutTrimming   Boolean @default(false)
  haircutSanitary   Boolean @default(false)
  haircutFace       Boolean @default(false)
  haircutPaws       Boolean @default(false)

  // === SECTION 4: DETAILS ===
  detailsNailTrimming  Boolean @default(false)
  detailsEarCleaning   Boolean @default(false)
  detailsAnalGlands    Boolean @default(false)
  detailsTeethBrushing Boolean @default(false)

  // === SECTION 4: EXTRAS ===
  extrasPerfume            Boolean @default(false)
  extrasBowsBandana        Boolean @default(false)
  extrasSpecialShampoo     Boolean @default(false)
  extrasSpecialShampooType String?

  // === SECTION 5: SPECIAL INSTRUCTIONS ===
  specialInstructions String? @db.Text

  // === SECTION 6: HEALTH CONDITIONS ===
  healthWounds           Boolean @default(false)
  healthSkinProblems     Boolean @default(false)
  healthOtitis           Boolean @default(false)
  healthAllergies        Boolean @default(false)
  healthFleasTicks       Boolean @default(false)
  healthChronicIllness   Boolean @default(false)
  healthUnderTreatment   Boolean @default(false)
  healthTreatmentDetails String?

  // === SECTION 7: AUTHORIZATION & CONSENT ===
  authorizeMuzzle      Boolean   @default(false)
  authorizeAdjustments Boolean   @default(false)
  ownerSignature       String?
  consentGiven         Boolean   @default(false)
  consentTimestamp     DateTime?

  // === STATUS TRACKING ===
  status        GroomingStatus @default(PENDIENTE)
  completedAt   DateTime?
  completedById String?
  notes         String?        @db.Text

  // === SECTION 8: EVERESTVET INTERNAL USE (Stylist fills) ===
  checkoutTime       DateTime?
  dischargeCondition DischargeCondition?
  stylistNotes       String?             @db.Text
  stylistId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitId])
  @@index([petId])
  @@index([status])
  @@index([serviceDate])
}

enum DischargeCondition {
  EXCELLENT
  GOOD
  REQUIRES_OBSERVATION
}

enum GroomingStatus {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  CANCELADO
}

// ============================================================================
// MÉDICO - Consultas, Laboratorio, Recetas, Cirugías, Hospitalización
// ============================================================================

model Consultation {
  id       String @id @default(cuid())
  visitId  String @unique
  visit    Visit  @relation(fields: [visitId], references: [id])
  petId    String
  pet      Pet    @relation(fields: [petId], references: [id])
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id])

  // === TIEMPOS ===
  startTime DateTime  @default(now())
  endTime   DateTime?
  duration  Int? // Duración en minutos (calculado)

  // === SOAP - Subjective (Lo que reporta el dueño) ===
  soapSubjective     String? @db.Text // Historia clínica del paciente
  motivoConsulta     String? @db.Text // Razón de la visita
  historiaEnfermedad String? @db.Text // Evolución del problema

  // === SOAP - Objective (Examen físico) ===
  soapObjective String? @db.Text // Hallazgos del examen
  physicalExam  String? @db.Text // Examen físico detallado

  // === SOAP - Assessment (Diagnóstico) ===
  soapAssessment String? @db.Text // Conclusión diagnóstica
  diagnosis      String? @db.Text // Diagnóstico (texto libre, legacy)

  // === SOAP - Plan (Tratamiento) ===
  soapPlan  String? @db.Text // Plan de tratamiento
  treatment String? @db.Text // Tratamiento (legacy)

  // === LEGACY FIELDS (mantener compatibilidad) ===
  symptoms String? @db.Text // Síntomas reportados
  notes    String? @db.Text // Notas adicionales

  // === SIGNOS VITALES AL INGRESO ===
  vitalTemperature     Float?
  vitalHeartRate       Int?
  vitalRespiratoryRate Int?
  vitalWeight          Float?
  vitalBloodPressure   String? // e.g., "120/80"
  vitalPulse           Int?
  vitalHydration       String? // Estado de hidratación
  vitalMucosas         String? // Color de mucosas

  // === SEGUIMIENTO ===
  followUpRequired Boolean   @default(false)
  followUpDate     DateTime?
  followUpNotes    String?   @db.Text

  // === ESTADO ===
  status ConsultationStatus @default(EN_PROGRESO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  diagnosticos             Diagnostico[]
  signosVitales            SignosVitales[]
  labRequests              LabRequest[]
  prescriptions            Prescription[]
  surgeries                Surgery[]
  hospitalization          Hospitalization?
  bloodTransfusionRequests BloodTransfusionRequest[]
  bloodTransfusions        BloodTransfusion[]

  @@index([petId])
  @@index([doctorId])
  @@index([startTime])
  @@index([status])
}

enum ConsultationStatus {
  EN_PROGRESO
  COMPLETADA
}

// === DIAGNÓSTICO (Estructura para CIE-10 y clasificación) ===
model Diagnostico {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  // === CLASIFICACIÓN CIE-10 ===
  codigoCIE10 String? // Código CIE-10 (ej: A00.1)
  nombreCIE10 String? // Nombre del código CIE-10

  // === DIAGNÓSTICO ===
  descripcion String          @db.Text // Descripción del diagnóstico
  tipo        DiagnosticoTipo @default(PRESUNTIVO)
  severidad   Severidad?

  // === DETALLES ===
  observaciones String? @db.Text
  diferenciales String? @db.Text // Diagnósticos diferenciales

  // === ORDEN ===
  orden       Int     @default(1) // Orden de prioridad
  esPrincipal Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consultationId])
  @@index([codigoCIE10])
}

enum DiagnosticoTipo {
  PRESUNTIVO
  DEFINITIVO
  DIFERENCIAL
}

enum Severidad {
  LEVE
  MODERADO
  SEVERO
  CRITICO
}

// === SIGNOS VITALES (Mediciones durante la consulta) ===
model SignosVitales {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  // === TIMESTAMP ===
  registeredAt DateTime @default(now())

  // === SIGNOS VITALES PRINCIPALES ===
  temperatura            Float? // °C
  frecuenciaCardiaca     Int? // lpm (latidos por minuto)
  frecuenciaRespiratoria Int? // rpm (respiraciones por minuto)
  peso                   Float? // kg

  // === SIGNOS VITALES SECUNDARIOS ===
  presionArterial   String? // e.g., "120/80 mmHg"
  pulso             Int? // ppm
  saturacionOxigeno Float? // SpO2 %
  glucosa           Float? // mg/dL

  // === ESTADO FÍSICO ===
  hidratacion          String? // Normal, Leve, Moderada, Severa
  mucosas              String? // Rosadas, Pálidas, Cianóticas, Ictéricas
  tiempoLlenadoCapilar String? // TLC en segundos
  condicionCorporal    Int? // Escala 1-9

  // === DOLOR ===
  escalaDolor       Int? // 0-10
  localizacionDolor String?

  // === OBSERVACIONES ===
  observaciones String? @db.Text

  createdAt DateTime @default(now())

  @@index([consultationId])
  @@index([registeredAt])
}

model LabRequest {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  petId          String
  pet            Pet          @relation(fields: [petId], references: [id])
  requestedById  String
  requestedBy    User         @relation("LabRequestedBy", fields: [requestedById], references: [id])
  requestedAt    DateTime     @default(now())

  // === ESTUDIO ===
  type    LabType
  urgency LabUrgency @default(NORMAL)
  notes   String?    @db.Text

  // === RESULTADOS ===
  status        LabRequestStatus @default(PENDIENTE)
  results       String?          @db.Text
  resultFiles   Json?
  completedAt   DateTime?
  completedById String?
  completedBy   User?            @relation("LabCompletedBy", fields: [completedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([petId])
  @@index([status])
  @@index([consultationId])
}

enum LabType {
  HEMOGRAMA
  QUIMICA_SANGUINEA
  URINALISIS
  RAYOS_X
  ULTRASONIDO
  ELECTROCARDIOGRAMA
  CITOLOGIA
  BIOPSIA
  COPROLOGIA
  PERFIL_TIROIDEO
}

enum LabUrgency {
  NORMAL
  URGENTE
}

enum LabRequestStatus {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
}

model Prescription {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  petId          String
  pet            Pet          @relation(fields: [petId], references: [id])
  prescribedById String
  prescribedBy   User         @relation(fields: [prescribedById], references: [id])
  prescribedAt   DateTime     @default(now())

  // === INSTRUCCIONES ===
  generalInstructions String? @db.Text

  // === ESTADO ===
  status PrescriptionStatus @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  items     PrescriptionItem[]
  dispenses Dispense[]

  @@index([petId])
  @@index([status])
  @@index([consultationId])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  // === TIPO DE MEDICAMENTO ===
  type PrescriptionItemType @default(USO_INMEDIATO)

  // === DATOS DEL MEDICAMENTO ===
  medicationId String? // Referencia a Medication si existe en inventario
  name         String
  dosage       String
  frequency    String
  duration     String
  quantity     Int
  instructions String? @db.Text

  // === DISPENSACIÓN ===
  dispensedQuantity Int @default(0) // Cantidad ya dispensada por farmacia

  // === PRECIOS (para cálculo en alta) ===
  unitPrice Decimal? @db.Decimal(10, 2)

  // === CÁLCULO DE DOSIS (trazabilidad) ===
  patientWeightKg   Float? // Peso del paciente usado para cálculo
  dosePerKg         Float? // mg/kg aplicado
  calculatedDoseMg  Float? // Dosis total calculada en mg
  volumeMl          Float? // Volumen calculado en ml (si aplica)
  concentrationUsed String? // Concentración usada para cálculo (ej: "50 mg/ml")

  createdAt DateTime @default(now())

  @@index([prescriptionId])
  @@index([type])
}

enum PrescriptionItemType {
  USO_INMEDIATO // Medicamento para usar en clínica, va a farmacia interna
  RECETA_EXTERNA // Medicamento para comprar afuera, se genera PDF
  APLICAR_AHORA // Medicamento aplicado en el momento por el médico/enfermero
}

enum PrescriptionStatus {
  PENDIENTE
  DESPACHADA
  PARCIAL
  CANCELADA
}

model Surgery {
  id             String       @id @default(cuid())
  petId          String
  pet            Pet          @relation(fields: [petId], references: [id])
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
